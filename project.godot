; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the format may change between versions.

config_version=5

[application]

config/name="Endless, Beloved"
config/description="A dark fantasy tarot visual novel"
config/version="0.1.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.2", "Mobile")
config/icon="res://assets/images/ui/icon.png"

[audio]

buses/default_bus_layout="res://assets/audio/default_bus_layout.tres"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"

[input]

swipe_left={
"deadzone": 0.2,
"events": []
}
swipe_right={
"deadzone": 0.2,
"events": []
}
tap={
"deadzone": 0.2,
"events": []
}

[autoload]

GameState="*res://scripts/core/GameState.gd"
SceneManager="*res://scripts/core/SceneManager.gd"
AudioManager="*res://scripts/core/AudioManager.gd"
CardManager="*res://scripts/core/CardManager.gd"
DialogueSystem="*res://scripts/core/DialogueSystem.gd"

[rendering]

textures/canvas_textures/default_texture_filter=2
renderer/rendering_method="mobile"